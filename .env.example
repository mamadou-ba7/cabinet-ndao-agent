# Clé API Groq — GRATUITE (obtenir sur console.groq.com/keys)
GROQ_API_KEY=gsk_VOTRE_CLE_ICI
# Modèle Groq (laisser par défaut)
GROQ_MODEL=llama-3.3-70b-versatile

# Gmail - Label à surveiller (laisser INBOX pour tous les mails)
GMAIL_LABEL=INBOX

# Mode: "draft" = crée des brouillons à valider | "auto" = envoie directement
# TOUJOURS laisser "draft" — l'avocat valide avant envoi
REPONSE_MODE=draft

# Numéro WhatsApp de l'avocat pour les alertes urgences (format international)
AVOCAT_WHATSAPP=+221775692867
